{
  "headers": [
    {
      "source": "/assets/images/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, s-maxage=31536000, immutable" }]
    },
    {
      "source": "/assets/logo/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, s-maxage=31536000, immutable" }]
    },
    {
      "source": "/assets/fonts/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, s-maxage=31536000, immutable" }]
    },
    {
      "source": "/assets/webfonts/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, s-maxage=31536000, immutable" }]
    },
    {
      "source": "/assets/vendor/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=31536000, stale-while-revalidate=604800" }]
    },
    {
      "source": "/assets/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=31536000, stale-while-revalidate=604800" }]
    },
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=31536000, stale-while-revalidate=604800" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=31536000, stale-while-revalidate=604800" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",            "value": "nosniff" },
        { "key": "X-Frame-Options",                   "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",                   "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",                "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
